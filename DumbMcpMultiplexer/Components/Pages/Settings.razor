@page "/settings"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Services
@inject ServerService ServerService

<PageTitle>Settings</PageTitle>

<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-white">Settings</h1>
        <p class="mt-2 text-gray-400">Configure global settings for the MCP proxy server.</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <div class="mb-4">
            <h2 class="text-xl font-semibold text-white">Progressive Tool Discovery</h2>
            <p class="mt-1 text-sm text-gray-400">
                When enabled, downstream clients see only lightweight <code class="text-gray-300">search_tools</code> and
                <code class="text-gray-300">list_tool_categories</code> meta-tools instead of the full tool list.
                This keeps LLM context small even when many upstream tools are available.
                Clients discover and call actual tools on demand.
            </p>
        </div>

        <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox"
                   checked="@_progressiveDiscovery"
                   @onchange="ToggleProgressiveDiscovery"
                   class="w-5 h-5 rounded bg-gray-800 border-gray-600 text-indigo-600 focus:ring-indigo-500" />
            <span class="text-white text-sm font-medium">Enable progressive discovery</span>
        </label>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <div class="mb-4">
            <h2 class="text-xl font-semibold text-white">Allowed Hosts</h2>
            <p class="mt-1 text-sm text-gray-400">
                Configure which hostnames are allowed to reach the <code class="text-gray-300">/mcp</code> endpoint.
                This provides protection against
                <a href="https://en.wikipedia.org/wiki/DNS_rebinding" target="_blank" class="text-indigo-400 hover:text-indigo-300 underline">DNS rebinding attacks</a>.
                Loopback addresses (<code class="text-gray-300">localhost</code>, <code class="text-gray-300">127.0.0.1</code>, <code class="text-gray-300">::1</code>) are always allowed regardless of this setting.
            </p>
        </div>

        <div class="space-y-2 mb-4">
            @if (_hosts.Count == 0)
            {
                <p class="text-gray-500 italic text-sm">No allowed hosts configured. Only loopback addresses will be permitted.</p>
            }
            else
            {
                @for (int i = 0; i < _hosts.Count; i++)
                {
                    var index = i;
                    <div class="flex items-center gap-2">
                        <input type="text"
                               value="@_hosts[index]"
                               @oninput="(e) => UpdateHost(index, e.Value?.ToString() ?? string.Empty)"
                               placeholder="e.g. myhost.example.com"
                               class="flex-1 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white font-mono text-sm placeholder-gray-500 focus:outline-none focus:border-indigo-500" />
                        <button @onclick="() => RemoveHost(index)"
                                class="text-gray-400 hover:text-red-400 px-2 py-1 text-lg font-bold"
                                title="Remove host">
                            ✕
                        </button>
                    </div>
                }
            }
        </div>

        <button @onclick="AddHost" class="text-indigo-400 hover:text-indigo-300 text-sm font-medium">
            + Add Host
        </button>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
        <div class="mb-4">
            <h2 class="text-xl font-semibold text-white">API Key</h2>
            <p class="mt-1 text-sm text-gray-400">
                When set, all requests to the <code class="text-gray-300">/mcp</code> endpoint must include the key as
                <code class="text-gray-300">Authorization: Bearer &lt;key&gt;</code> or <code class="text-gray-300">?api_key=&lt;key&gt;</code>.
                Leave unset to keep the endpoint open (e.g. for local-only use).
            </p>
        </div>

        @if (_apiKey is null)
        {
            <p class="text-gray-500 italic text-sm mb-4">No API key configured. The /mcp endpoint is publicly accessible.</p>
        }
        else
        {
            <div class="flex items-center gap-2 mb-4">
                <input type="@(_showApiKey ? "text" : "password")"
                       value="@_apiKey"
                       readonly
                       class="flex-1 bg-gray-800 border border-gray-700 rounded px-3 py-2 text-white font-mono text-sm focus:outline-none" />
                <button @onclick="() => _showApiKey = !_showApiKey"
                        class="text-gray-400 hover:text-white px-3 py-2 text-sm border border-gray-700 rounded bg-gray-800 hover:bg-gray-700 transition-colors">
                    @(_showApiKey ? "Hide" : "Show")
                </button>
            </div>
        }

        <div class="flex gap-2">
            <button @onclick="GenerateApiKey"
                    disabled="@_savingApiKey"
                    class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white font-medium rounded px-4 py-2 text-sm transition-colors">
                @(_apiKey is null ? "Generate API Key" : "Regenerate")
            </button>
            @if (_apiKey is not null)
            {
                <button @onclick="RevokeApiKey"
                        disabled="@_savingApiKey"
                        class="bg-red-900/50 hover:bg-red-800 disabled:opacity-50 text-red-300 font-medium rounded px-4 py-2 text-sm transition-colors border border-red-800">
                    Revoke
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="mt-4 bg-emerald-900/30 border border-emerald-800 rounded-lg px-4 py-3 text-emerald-300 text-sm">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mt-4 bg-red-900/30 border border-red-800 rounded-lg px-4 py-3 text-red-300 text-sm">
            @_errorMessage
        </div>
    }

    <div class="mt-6">
        <button @onclick="SaveSettings"
                disabled="@_saving"
                class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white font-medium rounded px-4 py-2 text-sm transition-colors">
            @if (_saving)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Save Settings</span>
            }
        </button>
    </div>
</div>

@code {
    private List<string> _hosts = new();
    private bool _progressiveDiscovery;
    private string? _apiKey;
    private bool _showApiKey;
    private bool _savingApiKey;
    private string? _successMessage;
    private string? _errorMessage;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var value = await ServerService.GetSettingAsync("allowed_hosts");
            if (!string.IsNullOrWhiteSpace(value))
            {
                _hosts = value.Split(',', StringSplitOptions.RemoveEmptyEntries)
                              .Select(h => h.Trim())
                              .ToList();
            }

            var pdValue = await ServerService.GetSettingAsync("progressive_discovery");
            _progressiveDiscovery = pdValue == "true";

            _apiKey = await ServerService.GetSettingAsync("api_key");
            if (string.IsNullOrWhiteSpace(_apiKey)) _apiKey = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load settings: {ex.Message}";
        }
    }

    private void ToggleProgressiveDiscovery(ChangeEventArgs e)
    {
        _progressiveDiscovery = (bool?)e.Value == true;
        ClearMessages();
    }

    private void AddHost()
    {
        _hosts.Add(string.Empty);
        ClearMessages();
    }

    private void RemoveHost(int index)
    {
        if (index >= 0 && index < _hosts.Count)
        {
            _hosts.RemoveAt(index);
            ClearMessages();
        }
    }

    private void UpdateHost(int index, string value)
    {
        if (index >= 0 && index < _hosts.Count)
        {
            _hosts[index] = value;
            ClearMessages();
        }
    }

    private async Task GenerateApiKey()
    {
        _savingApiKey = true;
        try
        {
            var bytes = System.Security.Cryptography.RandomNumberGenerator.GetBytes(32);
            _apiKey = Convert.ToBase64String(bytes).TrimEnd('=').Replace('+', '-').Replace('/', '_');
            _showApiKey = true;
            await ServerService.SetSettingAsync("api_key", _apiKey);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to generate API key: {ex.Message}";
        }
        finally
        {
            _savingApiKey = false;
        }
    }

    private async Task RevokeApiKey()
    {
        _savingApiKey = true;
        try
        {
            await ServerService.SetSettingAsync("api_key", string.Empty);
            _apiKey = null;
            _showApiKey = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to revoke API key: {ex.Message}";
        }
        finally
        {
            _savingApiKey = false;
        }
    }

    private async Task SaveSettings()
    {
        ClearMessages();
        _saving = true;

        try
        {
            var commaSeparatedValue = string.Join(",", _hosts.Where(h => !string.IsNullOrWhiteSpace(h)).Select(h => h.Trim()));
            await ServerService.SetSettingAsync("allowed_hosts", commaSeparatedValue);
            await ServerService.SetSettingAsync("progressive_discovery", _progressiveDiscovery ? "true" : "false");
            _successMessage = "Settings saved successfully.";

            // Refresh the list to remove any empty entries
            _hosts = commaSeparatedValue.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                        .Select(h => h.Trim())
                                        .ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ClearMessages()
    {
        _successMessage = null;
        _errorMessage = null;
    }
}
