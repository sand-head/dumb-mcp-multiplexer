@page "/settings"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Services
@inject ServerService ServerService

<PageTitle>Settings — dumb-mcp-multiplexer</PageTitle>

<div class="max-w-3xl">
    <div class="mb-10">
        <h1 class="font-serif italic text-5xl text-black leading-tight">Settings</h1>
        <p class="text-sm text-gray-500 mt-2">Configure global settings for the MCP proxy server.</p>
    </div>

    <div class="space-y-6">
        @* Allowed Hosts *@
        <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-6">
            <h2 class="font-serif italic text-2xl text-black mb-1">Allowed Hosts</h2>
            <p class="text-sm text-gray-500 mb-5">
                Configure which hostnames are allowed to reach the <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">/mcp</code> endpoint.
                This provides protection against
                <a href="https://en.wikipedia.org/wiki/DNS_rebinding" target="_blank" class="underline hover:text-black transition-colors">DNS rebinding attacks</a>.
                Loopback addresses (<code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">localhost</code>,
                <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">127.0.0.1</code>,
                <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">::1</code>) are always allowed.
            </p>

            <div class="space-y-2 mb-4">
                @if (_hosts.Count == 0)
                {
                    <p class="text-sm text-gray-400 italic">No allowed hosts configured. Only loopback addresses will be permitted.</p>
                }
                else
                {
                    @for (int i = 0; i < _hosts.Count; i++)
                    {
                        var index = i;
                        <div class="flex items-center gap-2">
                            <input type="text"
                                   value="@_hosts[index]"
                                   @oninput="(e) => UpdateHost(index, e.Value?.ToString() ?? string.Empty)"
                                   placeholder="e.g. myhost.example.com"
                                   class="flex-1 bg-white border-2 border-black px-3 py-2 text-black font-mono text-sm placeholder-gray-400 focus:outline-none" />
                            <button @onclick="() => RemoveHost(index)"
                                    class="text-gray-400 hover:text-red-600 px-2 py-1 text-lg font-bold transition-colors"
                                    title="Remove host">
                                ✕
                            </button>
                        </div>
                    }
                }
            </div>

            <button @onclick="AddHost" class="text-sm font-medium text-black underline hover:no-underline transition-colors">
                + Add Host
            </button>
        </div>

        @* API Key *@
        <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-6">
            <h2 class="font-serif italic text-2xl text-black mb-1">API Key</h2>
            <p class="text-sm text-gray-500 mb-5">
                When set, all requests to the <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">/mcp</code> endpoint must include the key as
                <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">Authorization: Bearer &lt;key&gt;</code> or
                <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5 text-xs">?api_key=&lt;key&gt;</code>.
                Leave unset to keep the endpoint open (e.g. for local-only use).
            </p>

            @if (_apiKey is null)
            {
                <p class="text-sm text-gray-400 italic mb-4">No API key configured. The /mcp endpoint is publicly accessible.</p>
            }
            else
            {
                <div class="flex items-center gap-2 mb-4">
                    <input type="@(_showApiKey ? "text" : "password")"
                           value="@_apiKey"
                           readonly
                           class="flex-1 bg-white border-2 border-black px-3 py-2 text-black font-mono text-sm focus:outline-none" />
                    <button @onclick="() => _showApiKey = !_showApiKey"
                            class="bg-white text-black text-sm font-medium px-3 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                        @(_showApiKey ? "Hide" : "Show")
                    </button>
                </div>
            }

            <div class="flex gap-3">
                <button @onclick="GenerateApiKey"
                        disabled="@_savingApiKey"
                        class="bg-black text-white text-sm font-semibold px-4 py-2 border-2 border-black transition-all hover:bg-gray-800 disabled:opacity-50">
                    @(_apiKey is null ? "Generate API Key" : "Regenerate")
                </button>
                @if (_apiKey is not null)
                {
                    <button @onclick="RevokeApiKey"
                            disabled="@_savingApiKey"
                            class="bg-white text-red-600 text-sm font-medium px-4 py-2 border-2 border-red-600 shadow-[3px_3px_0_0_#dc2626] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all disabled:opacity-50">
                        Revoke
                    </button>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="mt-5 border-2 border-emerald-600 bg-emerald-50 px-4 py-3 text-emerald-800 text-sm">
            @_successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mt-5 border-2 border-red-500 bg-red-50 px-4 py-3 text-red-700 text-sm">
            @_errorMessage
        </div>
    }

    <div class="mt-6">
        <button @onclick="SaveSettings"
                disabled="@_saving"
                class="bg-black text-white text-sm font-semibold px-5 py-2.5 border-2 border-black transition-all hover:bg-gray-800 disabled:opacity-50">
            @(_saving ? "Saving..." : "Save Settings")
        </button>
    </div>
</div>

@code {
    private List<string> _hosts = new();
    private string? _apiKey;
    private bool _showApiKey;
    private bool _savingApiKey;
    private string? _successMessage;
    private string? _errorMessage;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var value = await ServerService.GetSettingAsync("allowed_hosts");
            if (!string.IsNullOrWhiteSpace(value))
            {
                _hosts = value.Split(',', StringSplitOptions.RemoveEmptyEntries)
                              .Select(h => h.Trim())
                              .ToList();
            }

            _apiKey = await ServerService.GetSettingAsync("api_key");
            if (string.IsNullOrWhiteSpace(_apiKey)) _apiKey = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load settings: {ex.Message}";
        }
    }

    private void AddHost()
    {
        _hosts.Add(string.Empty);
        ClearMessages();
    }

    private void RemoveHost(int index)
    {
        if (index >= 0 && index < _hosts.Count)
        {
            _hosts.RemoveAt(index);
            ClearMessages();
        }
    }

    private void UpdateHost(int index, string value)
    {
        if (index >= 0 && index < _hosts.Count)
        {
            _hosts[index] = value;
            ClearMessages();
        }
    }

    private async Task GenerateApiKey()
    {
        _savingApiKey = true;
        try
        {
            var bytes = System.Security.Cryptography.RandomNumberGenerator.GetBytes(32);
            _apiKey = Convert.ToBase64String(bytes).TrimEnd('=').Replace('+', '-').Replace('/', '_');
            _showApiKey = true;
            await ServerService.SetSettingAsync("api_key", _apiKey);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to generate API key: {ex.Message}";
        }
        finally
        {
            _savingApiKey = false;
        }
    }

    private async Task RevokeApiKey()
    {
        _savingApiKey = true;
        try
        {
            await ServerService.SetSettingAsync("api_key", string.Empty);
            _apiKey = null;
            _showApiKey = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to revoke API key: {ex.Message}";
        }
        finally
        {
            _savingApiKey = false;
        }
    }

    private async Task SaveSettings()
    {
        ClearMessages();
        _saving = true;

        try
        {
            var commaSeparatedValue = string.Join(",", _hosts.Where(h => !string.IsNullOrWhiteSpace(h)).Select(h => h.Trim()));
            await ServerService.SetSettingAsync("allowed_hosts", commaSeparatedValue);
            _successMessage = "Settings saved successfully.";

            _hosts = commaSeparatedValue.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                        .Select(h => h.Trim())
                                        .ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ClearMessages()
    {
        _successMessage = null;
        _errorMessage = null;
    }
}
