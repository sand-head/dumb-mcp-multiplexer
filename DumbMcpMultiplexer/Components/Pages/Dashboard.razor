@page "/"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@inject ServerService ServerService

<PageTitle>Dashboard — dumb-mcp-multiplexer</PageTitle>

<div class="min-h-screen bg-gray-950 p-6 md:p-10">
    @* Header *@
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-white">Dashboard</h1>
            <p class="text-gray-400 text-sm mt-1">Manage your MCP server connections</p>
        </div>
        <button @onclick="OpenAddModal"
                class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow hover:bg-indigo-500 transition-colors">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Add Server
        </button>
    </div>

    @* Server grid or empty state *@
    @if (_servers is null)
    {
        <div class="flex items-center justify-center py-20">
            <div class="text-gray-400">Loading...</div>
        </div>
    }
    else if (_servers.Count == 0)
    {
        <div class="flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-gray-700 py-20">
            <svg class="h-12 w-12 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M5 12h14M12 5v14"/>
            </svg>
            <p class="text-gray-400 text-lg mb-2">No servers configured</p>
            <p class="text-gray-500 text-sm mb-6">Add your first MCP server to get started.</p>
            <button @onclick="OpenAddModal"
                    class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500 transition-colors">
                Add Server
            </button>
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var server in _servers)
            {
                <a href="/servers/@server.Slug"
                   class="group block rounded-2xl border border-gray-800 bg-gray-900 p-5 shadow transition-colors hover:border-gray-600 hover:bg-gray-800/80">
                    <div class="flex items-start justify-between mb-3">
                        <h2 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors truncate">
                            @server.Name
                        </h2>
                        <span class="ml-2 mt-1 flex-shrink-0">
                            @if (server.Enabled)
                            {
                                <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-500" title="Enabled"></span>
                            }
                            else
                            {
                                <span class="inline-block h-2.5 w-2.5 rounded-full bg-gray-600" title="Disabled"></span>
                            }
                        </span>
                    </div>
                    <p class="text-sm font-mono text-gray-400 mb-2 truncate">@server.Slug</p>
                    @if (!string.IsNullOrEmpty(server.Url))
                    {
                        <p class="text-xs text-gray-500 truncate" title="@server.Url">@server.Url</p>
                    }
                </a>
            }
        </div>
    }
</div>

@* Add Server Modal *@
@if (_showAddModal)
{
    <ServerForm Server="null"
                OnSaved="HandleServerSaved"
                OnCancel="CloseAddModal" />
}

@code {
    private List<McpServer>? _servers;
    private bool _showAddModal;

    protected override async Task OnInitializedAsync()
    {
        await LoadServers();
    }

    private async Task LoadServers()
    {
        _servers = await ServerService.GetAllServersAsync();
    }

    private void OpenAddModal()
    {
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
    }

    private async Task HandleServerSaved()
    {
        _showAddModal = false;
        await LoadServers();
    }
}
