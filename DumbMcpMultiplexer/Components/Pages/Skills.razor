@page "/skills"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@inject SkillService SkillService

<PageTitle>Skills — dumb-mcp-multiplexer</PageTitle>

<div>
    <div class="flex items-start justify-between mb-10">
        <div>
            <h1 class="font-serif italic text-5xl text-black leading-tight">Skills</h1>
            <p class="text-sm text-gray-500 mt-2">Reusable Lua scripts that agents can create and invoke via <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5">call_skill(name, args)</code> in Code Mode</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="mb-4 border-2 border-emerald-600 bg-emerald-50 px-4 py-3 text-emerald-800 text-sm">@_status</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="mb-4 border-2 border-red-500 bg-red-50 px-4 py-3 text-red-700 text-sm">@_error</div>
    }

    @if (_skills.Count == 0)
    {
        <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-8 text-center">
            <p class="text-gray-500 text-sm">No skills have been created yet.</p>
            <p class="text-gray-400 text-xs mt-2">
                When Code Mode is enabled, agents can create skills using the
                <code class="font-mono bg-gray-100 border border-gray-300 px-1 py-0.5">create_skill</code> tool.
                Skills persist globally and can be invoked from any Code Mode profile.
            </p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var skill in _skills)
            {
                <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-5">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-3">
                                <h3 class="font-serif italic text-2xl text-black">@skill.Name</h3>
                            </div>
                            <p class="text-sm text-gray-600 mt-1">@skill.Description</p>
                            <p class="text-xs text-gray-400 mt-2">
                                Last updated: @skill.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                            </p>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <button @onclick="() => ViewSkill(skill.Id)"
                                    class="bg-white text-black text-sm font-medium px-3 py-1.5 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                                View
                            </button>
                            <button @onclick="() => DeleteSkillAsync(skill.Id)"
                                    class="bg-white text-red-600 text-sm font-medium px-3 py-1.5 border-2 border-red-600 shadow-[3px_3px_0_0_#dc2626] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_viewingSkill is not null)
{
    <div class="fixed inset-0 z-50 bg-black/70 p-4 overflow-auto">
        <div class="max-w-4xl mx-auto bg-white border-2 border-black shadow-[8px_8px_0_0_#000] p-6 space-y-5 my-8">
            <div class="flex items-center justify-between border-b-2 border-black pb-4">
                <h3 class="font-serif italic text-3xl text-black">@_viewingSkill.Name</h3>
                <button @onclick="CloseView" class="text-gray-400 hover:text-black text-xl font-bold transition-colors">✕</button>
            </div>

            <div>
                <p class="text-sm text-gray-600">@_viewingSkill.Description</p>
                <p class="text-xs text-gray-400 mt-1">
                    Created: @_viewingSkill.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                    · Updated: @_viewingSkill.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                </p>
            </div>

            <div>
                <p class="text-xs uppercase tracking-widest text-gray-400 font-semibold mb-2">Lua Code</p>
                <pre class="bg-gray-900 text-gray-100 p-4 text-sm font-mono overflow-x-auto border-2 border-black whitespace-pre-wrap">@_viewingSkill.Code</pre>
            </div>

            <div class="flex justify-end border-t-2 border-black pt-4">
                <button @onclick="CloseView"
                        class="bg-white text-black text-sm font-medium px-4 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<SkillService.SkillSummary> _skills = [];
    private Skill? _viewingSkill;
    private string? _status;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadSkillsAsync();
    }

    private async Task LoadSkillsAsync()
    {
        _skills = await SkillService.GetAllAsync();
    }

    private async Task ViewSkill(string id)
    {
        _viewingSkill = await SkillService.GetByIdAsync(id);
    }

    private void CloseView()
    {
        _viewingSkill = null;
    }

    private async Task DeleteSkillAsync(string id)
    {
        _error = null;
        _status = null;

        var deleted = await SkillService.DeleteAsync(id);
        if (deleted)
        {
            await LoadSkillsAsync();
            _status = "Skill deleted.";
        }
        else
        {
            _error = "Skill not found.";
        }
    }
}
