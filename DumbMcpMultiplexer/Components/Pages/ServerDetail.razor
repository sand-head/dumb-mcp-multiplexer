@page "/servers/{Slug}"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@using DumbMcpMultiplexer.Components.Shared
@using System.Text.Json
@inject ServerService ServerService
@inject NavigationManager Navigation
@inject UpstreamManager UpstreamManager

<PageTitle>@(server?.Name ?? "Server") — dumb-mcp-multiplexer</PageTitle>

@if (loading)
{
    <div class="flex items-center justify-center min-h-[400px]">
        <p class="text-gray-400">Loading...</p>
    </div>
}
else if (server is null)
{
    <div class="flex flex-col items-center justify-center min-h-[400px] gap-4">
        <div class="text-6xl">🔍</div>
        <h2 class="text-2xl font-bold text-white">Server Not Found</h2>
        <p class="text-gray-400">No server with slug "<span class="font-mono text-yellow-400">@Slug</span>" exists.</p>
        <a href="/" class="mt-4 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors">
            ← Back to Dashboard
        </a>
    </div>
}
else
{
    @* Header *@
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
            <a href="/" class="text-gray-400 hover:text-white transition-colors text-sm">
                ← Back
            </a>
            <div>
                <h1 class="text-2xl font-bold text-white">@server.Name</h1>
                <p class="text-sm text-gray-400 font-mono">@server.Slug</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <button @onclick="ToggleEnabled"
                    class="@ToggleButtonClass px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                @(server.Enabled ? "Disable" : "Enable")
            </button>
            <button @onclick="OpenEditModal"
                    class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm font-medium transition-colors">
                Edit
            </button>
            <button @onclick="OpenDeleteModal"
                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors">
                Delete
            </button>
        </div>
    </div>

    @* Configuration Panel *@
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
        <h2 class="text-lg font-semibold text-white mb-4">Configuration</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @* Transport *@
            <div>
                <dt class="text-sm text-gray-400 mb-1">Transport</dt>
                <dd class="text-white font-medium">@FormatTransport(server.Transport)</dd>
            </div>

            @* Status *@
            <div>
                <dt class="text-sm text-gray-400 mb-1">Status</dt>
                <dd class="flex items-center gap-2">
                    <span class="@StatusDotClass w-2.5 h-2.5 rounded-full"></span>
                    <span class="@StatusTextClass font-medium">@(server.Enabled ? "Enabled" : "Disabled")</span>
                </dd>
            </div>

            @* URL *@
            <div>
                <dt class="text-sm text-gray-400 mb-1">@EndpointLabel</dt>
                <dd class="text-white font-mono text-sm break-all">
                    @EndpointValue
                </dd>
            </div>

            @* Custom Headers *@
            <div>
                <dt class="text-sm text-gray-400 mb-1">Custom Headers</dt>
                <dd class="text-white font-medium">@HeaderCount header@(HeaderCount == 1 ? "" : "s") configured</dd>
            </div>
        </div>
    </div>

    @* Tool Controls *@
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-4">
            <div>
                <h2 class="text-lg font-semibold text-white">Tool Controls</h2>
                <p class="text-sm text-gray-400">View discovered tools and enable or disable them individually.</p>
            </div>
            <button @onclick="RefreshToolsAsync"
                    disabled="@toolsLoading"
                    class="px-3 py-2 bg-gray-700 hover:bg-gray-600 disabled:bg-gray-800 disabled:text-gray-500 text-white rounded-lg text-sm font-medium transition-colors">
                @(toolsLoading ? "Refreshing..." : "Refresh Tools")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(toolsError))
        {
            <div class="mb-4 rounded-lg border border-yellow-700/50 bg-yellow-950/30 px-3 py-2 text-sm text-yellow-300">
                @toolsError
            </div>
        }

        @if (toolCapabilities.Count == 0)
        {
            <p class="text-sm text-gray-400">No tools discovered yet. Use "Refresh Tools" while this server is connected.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var capability in toolCapabilities)
                {
                    <div class="rounded-lg border border-gray-800 bg-gray-950/60 p-4">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-white font-mono text-sm">@capability.Name</p>
                                @if (!string.IsNullOrWhiteSpace(capability.Description))
                                {
                                    <p class="text-sm text-gray-400 mt-1">@capability.Description</p>
                                }
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="text-xs px-2 py-1 rounded-full @(capability.Enabled ? "bg-green-950 text-green-300 border border-green-800" : "bg-red-950 text-red-300 border border-red-800")">
                                    @(capability.Enabled ? "Enabled" : "Disabled")
                                </span>
                                <button @onclick="() => ToggleToolEnabledAsync(capability.Name)"
                                        class="px-3 py-1.5 rounded-md text-xs font-medium transition-colors @(capability.Enabled ? "bg-yellow-600 hover:bg-yellow-700 text-white" : "bg-green-600 hover:bg-green-700 text-white")">
                                    @(capability.Enabled ? "Disable" : "Enable")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Namespace Prefix *@
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-2">Namespace Prefix</h2>
        <p class="text-sm text-gray-400 mb-3">
            Tools from this server are exposed with the following prefix to avoid naming collisions:
        </p>
        <div class="bg-gray-950 border border-gray-800 rounded-lg px-4 py-3">
            <code class="text-green-400 text-sm font-mono">@(server.Slug)__&lt;tool_name&gt;</code>
        </div>
    </div>

    @* Edit Modal *@
    @if (showEditModal)
    {
        <ServerForm Server="server" OnSaved="OnEditSaved" OnCancel="CloseEditModal" />
    }

    @* Delete Confirmation Modal *@
    @if (showDeleteModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
            <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 w-full max-w-md mx-4 shadow-2xl">
                <h3 class="text-xl font-bold text-white mb-2">Delete Server</h3>
                <p class="text-gray-300 mb-1">
                    Are you sure you want to delete <span class="font-semibold text-white">@server.Name</span>?
                </p>
                <p class="text-sm text-gray-400 mb-6">
                    This action cannot be undone. All tool namespace mappings for this server will be removed.
                </p>
                <div class="flex justify-end gap-3">
                    <button @onclick="CloseDeleteModal"
                            class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg text-sm font-medium transition-colors">
                        Cancel
                    </button>
                    <button @onclick="ConfirmDelete"
                            class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private McpServer? server;
    private bool loading = true;
    private bool showEditModal;
    private bool showDeleteModal;
    private bool toolsLoading;
    private string? toolsError;
    private List<ServerCapability> toolCapabilities = [];

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        toolsError = null;
        server = await ServerService.GetServerBySlugAsync(Slug);
        await LoadToolCapabilitiesAsync();
        loading = false;
    }

    private int HeaderCount =>
        server is null ? 0 : (JsonSerializer.Deserialize<Dictionary<string, string>>(server.Headers)?.Count ?? 0);

    private string ToggleButtonClass =>
        server?.Enabled == true
            ? "bg-yellow-600 hover:bg-yellow-700 text-white"
            : "bg-green-600 hover:bg-green-700 text-white";

    private string StatusDotClass =>
        server?.Enabled == true ? "bg-green-500" : "bg-red-500";

    private string StatusTextClass =>
        server?.Enabled == true ? "text-green-400" : "text-red-400";

    private static string FormatTransport(string transport) => transport switch
    {
        "remote_http" => "Remote HTTP (SSE)",
        "remote_streamable_http" => "Remote Streamable HTTP",
        "stdio_container" => "Container (stdio)",
        _ => transport
    };

    private string EndpointLabel => server?.Transport == "stdio_container" ? "Container Image" : "URL";

    private string EndpointValue =>
        server is null
            ? "—"
            : server.Transport == "stdio_container"
                ? (string.IsNullOrWhiteSpace(server.ContainerImage) ? "—" : server.ContainerImage)
                : (string.IsNullOrWhiteSpace(server.Url) ? "—" : server.Url);

    private async Task ToggleEnabled()
    {
        if (server is null) return;
        await ServerService.ToggleServerEnabledAsync(server.Id);
        server = await ServerService.GetServerBySlugAsync(Slug);
        _ = Task.Run(() => UpstreamManager.SyncAsync());
    }

    private void OpenEditModal() => showEditModal = true;

    private void CloseEditModal() => showEditModal = false;

    private async Task OnEditSaved()
    {
        showEditModal = false;
        // Reload by ID since the slug may have changed during edit
        var id = server?.Id;
        if (id is not null)
        {
            server = await ServerService.GetServerByIdAsync(id);
        }
        // If the slug changed, navigate to the new URL
        if (server is not null && server.Slug != Slug)
        {
            Navigation.NavigateTo($"/servers/{server.Slug}", replace: true);
        }
        await LoadToolCapabilitiesAsync();
    }

    private void OpenDeleteModal() => showDeleteModal = true;

    private void CloseDeleteModal() => showDeleteModal = false;

    private async Task ConfirmDelete()
    {
        if (server is null) return;
        await ServerService.DeleteServerAsync(server.Id);
        _ = Task.Run(() => UpstreamManager.SyncAsync());
        Navigation.NavigateTo("/");
    }

    private async Task LoadToolCapabilitiesAsync()
    {
        if (server is null)
        {
            toolCapabilities = [];
            return;
        }

        toolCapabilities = await ServerService.GetToolCapabilitiesAsync(server.Id);
    }

    private async Task RefreshToolsAsync()
    {
        if (server is null)
        {
            return;
        }

        toolsLoading = true;
        toolsError = null;
        try
        {
            if (!UpstreamManager.Connections.TryGetValue(server.Slug, out var client))
            {
                toolsError = "Server is not currently connected. Showing last discovered tools.";
                await LoadToolCapabilitiesAsync();
                return;
            }

            var discoveredTools = await client.ListToolsAsync();
            await ServerService.SyncToolCapabilitiesAsync(
                server.Id,
                discoveredTools.Select(tool => (
                    tool.Name,
                    (string?)tool.Description,
                    tool.JsonSchema.ValueKind == JsonValueKind.Undefined ? null : JsonSerializer.Serialize(tool.JsonSchema))));

            await LoadToolCapabilitiesAsync();
        }
        catch (Exception ex)
        {
            toolsError = $"Failed to refresh tools: {ex.Message}";
            await LoadToolCapabilitiesAsync();
        }
        finally
        {
            toolsLoading = false;
        }
    }

    private async Task ToggleToolEnabledAsync(string toolName)
    {
        if (server is null)
        {
            return;
        }

        await ServerService.ToggleToolCapabilityEnabledAsync(server.Id, toolName);
        await LoadToolCapabilitiesAsync();
    }
}
