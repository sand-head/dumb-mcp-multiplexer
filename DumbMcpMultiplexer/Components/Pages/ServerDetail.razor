@page "/servers/{Slug}"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@using DumbMcpMultiplexer.Components.Shared
@using System.Text.Json
@inject ServerService ServerService
@inject NavigationManager Navigation
@inject UpstreamManager UpstreamManager
@inject StdioLifecycleService StdioLifecycleService
@inject ImageBuilderService ImageBuilder

<PageTitle>@(server?.Name ?? "Server") — dumb-mcp-multiplexer</PageTitle>

@if (loading)
{
    <div class="flex items-center justify-center min-h-[400px]">
        <p class="font-serif italic text-2xl text-gray-400">Loading...</p>
    </div>
}
else if (server is null)
{
    <div class="flex flex-col items-center justify-center min-h-[400px] gap-4">
        <div class="text-6xl">🔍</div>
        <h2 class="font-serif italic text-3xl text-black">Server Not Found</h2>
        <p class="text-gray-500">No server with slug "<span class="font-mono text-black">@Slug</span>" exists.</p>
        <a href="/" class="mt-4 bg-white text-black text-sm font-medium px-4 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
            ← Back to Dashboard
        </a>
    </div>
}
else
{
    @* Header *@
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
        <div class="flex items-center gap-4">
            <a href="/" class="text-sm text-gray-500 hover:text-black hover:underline transition-colors">← Back</a>
            <div>
                <h1 class="font-serif italic text-4xl text-black leading-tight">@server.Name</h1>
                <p class="text-xs font-mono text-gray-500 mt-0.5">@server.Slug</p>
            </div>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            @if (!string.IsNullOrWhiteSpace(server.Containerfile))
            {
                <button @onclick="RebuildImage"
                        disabled="@rebuilding"
                        class="bg-black text-white text-sm font-semibold px-4 py-2 border-2 border-black transition-all hover:bg-gray-800 disabled:opacity-50">
                    @(rebuilding ? "Rebuilding..." : "Rebuild Image")
                </button>
            }
            <button @onclick="ToggleEnabled"
                    class="@ToggleButtonClass text-sm font-semibold px-4 py-2 border-2 transition-all">
                @(server.Enabled ? "Disable" : "Enable")
            </button>
            <button @onclick="OpenEditModal"
                    class="bg-white text-black text-sm font-medium px-4 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                Edit
            </button>
            <button @onclick="OpenDeleteModal"
                    class="bg-white text-red-600 text-sm font-medium px-4 py-2 border-2 border-red-600 shadow-[3px_3px_0_0_#dc2626] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                Delete
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(rebuildMessage))
    {
        <div class="mb-6 border-2 @(rebuildSuccess ? "border-emerald-600 bg-emerald-50 text-emerald-800" : "border-red-500 bg-red-50 text-red-700") px-4 py-3 text-sm">
            @rebuildMessage
        </div>
    }

    @* Configuration Panel *@
    <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-6 mb-6">
        <h2 class="font-serif italic text-2xl text-black mb-5">Configuration</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <dt class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Transport</dt>
                <dd class="text-black font-medium">@FormatTransport(server.Transport)</dd>
            </div>

            <div>
                <dt class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Status</dt>
                @{
                    var status = GetStatusBadge();
                }
                <dd class="flex items-center gap-2">
                    <span class="inline-flex items-center gap-1 text-xs font-mono font-semibold px-2 py-0.5 @status.BadgeClass">
                        @if (status.ShowSpinner)
                        {
                            <svg class="h-3 w-3 animate-spin" viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-20" cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
                                <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                            </svg>
                        }
                        @status.Label
                    </span>
                </dd>
                @if (ShowLifecycleDiagnostics)
                {
                    <p class="mt-2 text-xs text-gray-500">Retry count: @CurrentLifecycleStatus!.RetryCount</p>
                    @if (!string.IsNullOrWhiteSpace(CurrentLifecycleStatus.LastError))
                    {
                        <p class="mt-1 text-xs text-red-600">@CurrentLifecycleStatus.LastError</p>
                    }
                }
            </div>

            <div>
                <dt class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">@EndpointLabel</dt>
                <dd class="text-black font-mono text-sm break-all">@EndpointValue</dd>
            </div>

            <div>
                <dt class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Custom Headers</dt>
                <dd class="text-black font-medium">@HeaderCount header@(HeaderCount == 1 ? "" : "s") configured</dd>
            </div>
        </div>
    </div>

    @* Tool Controls *@
    <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-6 mb-6">
        <div class="flex items-start justify-between gap-4 mb-5">
            <div>
                <h2 class="font-serif italic text-2xl text-black">Tool Controls</h2>
                <p class="text-sm text-gray-500 mt-1">View discovered tools and enable or disable them individually.</p>
            </div>
            <button @onclick="RefreshToolsAsync"
                    disabled="@toolsLoading"
                    class="bg-white text-black text-sm font-medium px-4 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all disabled:opacity-50 shrink-0">
                @(toolsLoading ? "Refreshing..." : "Refresh Tools")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(toolsError))
        {
            <div class="mb-4 border-2 border-yellow-500 bg-yellow-50 px-3 py-2 text-sm text-yellow-800">
                @toolsError
            </div>
        }

        @if (toolCapabilities.Count == 0)
        {
            <p class="text-sm text-gray-400 italic">No tools discovered yet. Use "Refresh Tools" while this server is connected.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var capability in toolCapabilities)
                {
                    <div class="border-2 border-black p-4 bg-gray-50">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-black font-mono text-sm">@capability.Name</p>
                                @if (!string.IsNullOrWhiteSpace(capability.Description))
                                {
                                    <p class="text-sm text-gray-500 mt-1">@capability.Description</p>
                                }
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <span class="text-xs font-mono font-semibold px-2 py-0.5 @(capability.Enabled ? "bg-emerald-500 text-white" : "bg-gray-100 text-gray-600 border border-gray-400")">
                                    @(capability.Enabled ? "Enabled" : "Disabled")
                                </span>
                                <button @onclick="() => ToggleToolEnabledAsync(capability.Name)"
                                        class="@(capability.Enabled ? "bg-white text-amber-700 border-amber-600 shadow-[2px_2px_0_0_#d97706]" : "bg-white text-emerald-700 border-emerald-600 shadow-[2px_2px_0_0_#059669]") text-xs font-medium px-3 py-1.5 border-2 hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
                                    @(capability.Enabled ? "Disable" : "Enable")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Namespace Prefix *@
    <div class="bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-6">
        <h2 class="font-serif italic text-2xl text-black mb-2">Namespace Prefix</h2>
        <p class="text-sm text-gray-500 mb-4">
            Tools from this server are exposed with the following prefix to avoid naming collisions:
        </p>
        <div class="bg-gray-50 border-2 border-black px-4 py-3">
            <code class="text-black font-mono text-sm">@(server.Slug)__&lt;tool_name&gt;</code>
        </div>
    </div>

    @* Edit Modal *@
    @if (showEditModal)
    {
        <ServerForm Server="server" OnSaved="OnEditSaved" OnCancel="CloseEditModal" />
    }

    @* Delete Confirmation Modal *@
    @if (showDeleteModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/70">
            <div class="bg-white border-2 border-black shadow-[8px_8px_0_0_#000] p-6 w-full max-w-md mx-4">
                <h3 class="font-serif italic text-3xl text-black mb-3">Delete Server</h3>
                <p class="text-black mb-1">
                    Are you sure you want to delete <span class="font-semibold">@server.Name</span>?
                </p>
                <p class="text-sm text-gray-500 mb-6">
                    This action cannot be undone. All tool namespace mappings for this server will be removed.
                </p>
                <div class="flex justify-end gap-3">
                    <button @onclick="CloseDeleteModal"
                            class="bg-white text-black text-sm font-medium px-4 py-2 border-2 border-black shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all">
                        Cancel
                    </button>
                    <button @onclick="ConfirmDelete"
                            class="bg-red-600 text-white text-sm font-semibold px-4 py-2 border-2 border-red-800 transition-all hover:bg-red-700">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private McpServer? server;
    private bool loading = true;
    private bool showEditModal;
    private bool showDeleteModal;
    private bool toolsLoading;
    private bool rebuilding;
    private string? toolsError;
    private string? rebuildMessage;
    private bool rebuildSuccess;
    private List<ServerCapability> toolCapabilities = [];

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        toolsError = null;
        server = await ServerService.GetServerBySlugAsync(Slug);
        await LoadToolCapabilitiesAsync();
        loading = false;
    }

    private int HeaderCount =>
        server is null ? 0 : (JsonSerializer.Deserialize<Dictionary<string, string>>(server.Headers)?.Count ?? 0);

    private string ToggleButtonClass =>
        server?.Enabled == true
            ? "bg-white text-amber-700 border-amber-600 shadow-[3px_3px_0_0_#d97706] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]"
            : "bg-white text-emerald-700 border-emerald-600 shadow-[3px_3px_0_0_#059669] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px]";

    private LifecycleStatus? CurrentLifecycleStatus =>
        server is null || (server.Transport != "stdio_package_runner" && server.Transport != "stdio_container")
            ? null
            : StdioLifecycleService.States.TryGetValue(server.Slug, out var status)
                ? status
                : null;

    private bool ShowLifecycleDiagnostics =>
        CurrentLifecycleStatus is not null
        && (CurrentLifecycleStatus.State == LifecycleState.Crashed || CurrentLifecycleStatus.State == LifecycleState.Restarting);

    private UpstreamHealthStatus GetHealthStatus(string slug)
    {
        if (!UpstreamManager.Connections.ContainsKey(slug))
            return UpstreamHealthStatus.Degraded;
        return UpstreamManager.HealthStatuses.TryGetValue(slug, out var status)
            ? status
            : UpstreamHealthStatus.Healthy;
    }

    private ServerStatusBadge GetStatusBadge()
    {
        if (server?.Enabled != true)
        {
            return new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400");
        }

        if (CurrentLifecycleStatus is not null)
        {
            return CurrentLifecycleStatus.State switch
            {
                LifecycleState.Running => new ServerStatusBadge("Running", "bg-emerald-500 text-white"),
                LifecycleState.Crashed => new ServerStatusBadge("Crashed", "bg-red-500 text-white"),
                LifecycleState.Restarting => new ServerStatusBadge("Restarting", "bg-amber-400 text-black", true),
                _ => new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400"),
            };
        }

        if (!UpstreamManager.Connections.ContainsKey(server!.Slug))
        {
            return new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400");
        }

        return GetHealthStatus(server.Slug) == UpstreamHealthStatus.Degraded
            ? new ServerStatusBadge("Degraded", "bg-amber-400 text-black")
            : new ServerStatusBadge("Running", "bg-emerald-500 text-white");
    }

    private static string FormatTransport(string transport) => transport switch
    {
        "remote_http" => "Remote HTTP (SSE)",
        "remote_streamable_http" => "Remote Streamable HTTP",
        "stdio_package_runner" => "Package Runner (stdio)",
        "stdio_container" => "Container (stdio)",
        _ => transport
    };

    private string EndpointLabel => server?.Transport switch
    {
        "stdio_package_runner" => "Runner",
        "stdio_container" => "Image",
        _ => "URL"
    };

    private string EndpointValue =>
        server is null
            ? "—"
            : server.Transport == "stdio_package_runner"
                ? $"{server.PackageRunner} — {server.Command ?? "(no command)"}"
                : server.Transport == "stdio_container"
                        ? (!string.IsNullOrWhiteSpace(server.ContainerImage)
                            ? server.ContainerImage
                            : !string.IsNullOrWhiteSpace(server.Containerfile)
                                ? "(custom Containerfile)"
                                : "—")
                    : (string.IsNullOrWhiteSpace(server.Url) ? "—" : server.Url);

    private async Task ToggleEnabled()
    {
        if (server is null) return;
        await ServerService.ToggleServerEnabledAsync(server.Id);
        server = await ServerService.GetServerBySlugAsync(Slug);
        _ = Task.Run(() => UpstreamManager.SyncAsync());
    }

    private async Task RebuildImage()
    {
        if (server is null) return;
        rebuilding = true;
        rebuildMessage = null;
        try
        {
            var imageTag = await ImageBuilder.RebuildImageAsync(server);
            rebuildMessage = $"Image rebuilt successfully: {imageTag}";
            rebuildSuccess = true;
            await UpstreamManager.DisconnectAsync(server.Slug);
            await UpstreamManager.SyncAsync();
        }
        catch (Exception ex)
        {
            rebuildMessage = $"Rebuild failed: {ex.Message}";
            rebuildSuccess = false;
        }
        finally
        {
            rebuilding = false;
        }
    }

    private void OpenEditModal() => showEditModal = true;

    private void CloseEditModal() => showEditModal = false;

    private async Task OnEditSaved()
    {
        showEditModal = false;
        var id = server?.Id;
        if (id is not null)
        {
            server = await ServerService.GetServerByIdAsync(id);
        }
        if (server is not null && server.Slug != Slug)
        {
            Navigation.NavigateTo($"/servers/{server.Slug}", replace: true);
        }
        await LoadToolCapabilitiesAsync();
    }

    private void OpenDeleteModal() => showDeleteModal = true;

    private void CloseDeleteModal() => showDeleteModal = false;

    private async Task ConfirmDelete()
    {
        if (server is null) return;
        await ServerService.DeleteServerAsync(server.Id);
        _ = Task.Run(() => UpstreamManager.SyncAsync());
        Navigation.NavigateTo("/");
    }

    private async Task LoadToolCapabilitiesAsync()
    {
        if (server is null)
        {
            toolCapabilities = [];
            return;
        }

        toolCapabilities = await ServerService.GetToolCapabilitiesAsync(server.Id);
    }

    private async Task RefreshToolsAsync()
    {
        if (server is null)
        {
            return;
        }

        toolsLoading = true;
        toolsError = null;
        try
        {
            if (!UpstreamManager.Connections.TryGetValue(server.Slug, out var client))
            {
                toolsError = "Server is not currently connected. Showing last discovered tools.";
                await LoadToolCapabilitiesAsync();
                return;
            }

            var discoveredTools = await client.ListToolsAsync();
            await ServerService.SyncToolCapabilitiesAsync(
                server.Id,
                discoveredTools.Select(tool => (
                    tool.Name,
                    (string?)tool.Description,
                    tool.JsonSchema.ValueKind == JsonValueKind.Undefined ? null : JsonSerializer.Serialize(tool.JsonSchema))));

            await LoadToolCapabilitiesAsync();
        }
        catch (Exception ex)
        {
            toolsError = $"Failed to refresh tools: {ex.Message}";
            await LoadToolCapabilitiesAsync();
        }
        finally
        {
            toolsLoading = false;
        }
    }

    private async Task ToggleToolEnabledAsync(string toolName)
    {
        if (server is null)
        {
            return;
        }

        await ServerService.ToggleToolCapabilityEnabledAsync(server.Id, toolName);
        await LoadToolCapabilitiesAsync();
    }

    private sealed record ServerStatusBadge(string Label, string BadgeClass, bool ShowSpinner = false);
}
