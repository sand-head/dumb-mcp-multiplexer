@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@using System.Text.Json
@using System.Text.RegularExpressions
@inject ServerService ServerService
@inject UpstreamManager UpstreamManager

@* Modal backdrop *@
<div class="fixed inset-0 z-50 flex items-center justify-center">
    @* Backdrop *@
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @onclick="Cancel"></div>

    @* Modal card *@
    <div class="relative z-10 w-full max-w-lg mx-4 rounded-2xl border border-gray-700 bg-gray-900 p-6 shadow-2xl max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white">
                @(IsEditMode ? "Edit Server" : "Add Server")
            </h2>
            <button @onclick="Cancel"
                    class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form @onsubmit="HandleSubmit" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-white mb-1.5">Name</label>
                <input type="text"
                       value="@_name"
                       @oninput="OnNameChanged"
                       placeholder="My MCP Server"
                       class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
            </div>

            <div>
                <label class="block text-sm font-medium text-white mb-1.5">Slug</label>
                <input type="text"
                       value="@_slug"
                       @oninput="OnSlugManuallyEdited"
                       placeholder="my-mcp-server"
                       class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                @if (!string.IsNullOrEmpty(_slugError))
                {
                    <p class="mt-1 text-xs text-red-400">@_slugError</p>
                }
                else
                {
                    <p class="mt-1 text-xs text-gray-500">URL-safe identifier (lowercase, hyphens, underscores)</p>
                }
            </div>

            <div>
                <label class="block text-sm font-medium text-white mb-1.5">Transport</label>
                <select value="@_transport"
                        @onchange="OnTransportChanged"
                        class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-white text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                    <option value="remote_http">Remote HTTP</option>
                    <option value="stdio_container">Container</option>
                </select>
            </div>

            @if (_transport == "remote_http")
            {
                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">URL</label>
                    <input type="url"
                           value="@_url"
                           @oninput="(e) => _url = e.Value?.ToString() ?? string.Empty"
                           placeholder="https://example.com/mcp"
                           class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Headers</label>
                    <div class="space-y-2">
                        @for (int i = 0; i < _headers.Count; i++)
                        {
                            var index = i;
                            <div class="flex gap-2">
                                <input type="text"
                                       value="@_headers[index].Key"
                                       @oninput="(e) => UpdateHeaderKey(index, e.Value?.ToString() ?? string.Empty)"
                                       placeholder="Header-Name"
                                       class="flex-1 rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-xs focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                                <input type="text"
                                       value="@_headers[index].Value"
                                       @oninput="(e) => UpdateHeaderValue(index, e.Value?.ToString() ?? string.Empty)"
                                       placeholder="value"
                                       class="flex-1 rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-xs focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                                <button type="button" @onclick="() => RemoveHeader(index)"
                                        class="rounded-lg p-2 text-gray-400 hover:bg-gray-800 hover:text-red-400 transition-colors">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                    <button type="button" @onclick="AddHeader"
                            class="mt-2 inline-flex items-center gap-1 rounded-lg border border-dashed border-gray-700 px-3 py-1.5 text-xs text-gray-400 hover:border-gray-500 hover:text-gray-300 transition-colors">
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Add Header
                    </button>
                </div>
            }
            else if (_transport == "stdio_container")
            {
                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Container Mode</label>
                    <select value="@_containerMode"
                            @onchange="OnContainerModeChanged"
                            class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-white text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                        <option value="image">Pre-built Image (Tier 1)</option>
                        <option value="autobuild">Auto-build (Tier 2)</option>
                    </select>
                </div>

                @if (_containerMode == "image")
                {
                    <div>
                        <label class="block text-sm font-medium text-white mb-1.5">Container Image</label>
                        <input type="text"
                               value="@_containerImage"
                               @oninput="(e) => _containerImage = e.Value?.ToString() ?? string.Empty"
                               placeholder="ghcr.io/org/mcp-server:latest"
                               class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                    </div>
                }
                else
                {
                    <div>
                        <label class="block text-sm font-medium text-white mb-1.5">Runtime</label>
                        <select value="@_containerRuntime"
                                @onchange="(e) => _containerRuntime = e.Value?.ToString() ?? string.Empty"
                                class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-white text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                            <option value="">— Select Runtime —</option>
                            <option value="node">Node (npm)</option>
                            <option value="python">Python (pip)</option>
                            <option value="uvx">Python (uv/uvx)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-white mb-1.5">Packages</label>
                        <input type="text"
                               value="@_containerPackagesInput"
                               @oninput="(e) => _containerPackagesInput = e.Value?.ToString() ?? string.Empty"
                               placeholder="package1 package2"
                               class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                        <p class="mt-1 text-xs text-gray-500">Space-separated list of packages to install</p>
                    </div>
                }

                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Command</label>
                    <input type="text"
                           value="@_command"
                           @oninput="(e) => _command = e.Value?.ToString() ?? string.Empty"
                           placeholder="uvx"
                           class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none" />
                    <p class="mt-1 text-xs text-gray-500">Executable plus optional extra tokens (split on spaces).</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Args (JSON array)</label>
                    <textarea rows="3"
                              value="@_argsJson"
                              @oninput="(e) => _argsJson = e.Value?.ToString() ?? string.Empty"
                              placeholder="[\"music-assistant-mcp\"]"
                              class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-xs focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Env (JSON object)</label>
                    <textarea rows="3"
                              value="@_envJson"
                              @oninput="(e) => _envJson = e.Value?.ToString() ?? string.Empty"
                              placeholder="{\"KEY\":\"VALUE\"}"
                              class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-xs focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-white mb-1.5">Mounts (JSON array)</label>
                    <textarea rows="3"
                              value="@_mountsJson"
                              @oninput="(e) => _mountsJson = e.Value?.ToString() ?? string.Empty"
                              placeholder='["/host/path:/container/path:ro"]'
                              class="w-full rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 font-mono text-white placeholder-gray-500 text-xs focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></textarea>
                </div>
            }

            <div>
                <button type="button" @onclick="TestConnection"
                        class="inline-flex items-center gap-2 rounded-lg border border-gray-700 px-3 py-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Test Connection
                </button>
                @if (!string.IsNullOrEmpty(_testMessage))
                {
                    <p class="mt-2 text-xs @(_testSuccess ? "text-emerald-400" : "text-yellow-400")">@_testMessage</p>
                }
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="rounded-lg border border-red-800 bg-red-900/30 px-4 py-3 text-sm text-red-300">
                    @_formError
                </div>
            }

            <div class="flex items-center justify-end gap-3 pt-2">
                <button type="button" @onclick="Cancel"
                        class="rounded-lg border border-gray-700 px-4 py-2 text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-colors">
                    Cancel
                </button>
                <button type="submit" disabled="@_saving"
                        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow hover:bg-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    @if (_saving)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>@(IsEditMode ? "Save Changes" : "Create Server")</span>
                    }
                </button>
            </div>
        </form>
    </div>
</div>

@code {
    [Parameter] public McpServer? Server { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsEditMode => Server is not null;

    private string _name = string.Empty;
    private string _slug = string.Empty;
    private string _transport = "remote_http";
    private string _url = string.Empty;
    private List<HeaderEntry> _headers = [];

    private string _command = string.Empty;
    private string _argsJson = "[]";
    private string _envJson = "{}";
    private string _containerImage = string.Empty;
    private string _containerRuntime = string.Empty;
    private string _containerPackagesInput = string.Empty;
    private string _containerMode = "image";
    private string _mountsJson = "[]";

    private string? _slugError;
    private string? _formError;
    private string? _testMessage;
    private bool _testSuccess;
    private bool _saving;
    private bool _slugManuallyEdited;

    private class HeaderEntry
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    protected override void OnInitialized()
    {
        if (Server is null)
        {
            return;
        }

        _name = Server.Name;
        _slug = Server.Slug;
        _transport = string.IsNullOrWhiteSpace(Server.Transport) ? "remote_http" : Server.Transport;
        _url = Server.Url ?? string.Empty;
        _command = Server.Command ?? string.Empty;
        _argsJson = string.IsNullOrWhiteSpace(Server.Args) ? "[]" : (Server.Args ?? "[]");
        _envJson = string.IsNullOrWhiteSpace(Server.Env) ? "{}" : (Server.Env ?? "{}");
        _containerImage = Server.ContainerImage ?? string.Empty;
        _containerRuntime = Server.ContainerRuntime ?? string.Empty;
        _mountsJson = string.IsNullOrWhiteSpace(Server.ContainerMounts) ? "[]" : Server.ContainerMounts;
        _slugManuallyEdited = true;

        // Determine container mode based on existing data
        if (_transport == "stdio_container")
        {
            _containerMode = !string.IsNullOrWhiteSpace(Server.ContainerRuntime) ? "autobuild" : "image";
        }

        // Parse packages JSON array into space-separated input string
        if (!string.IsNullOrWhiteSpace(Server.ContainerPackages) && Server.ContainerPackages != "[]")
        {
            try
            {
                var packages = JsonSerializer.Deserialize<List<string>>(Server.ContainerPackages);
                _containerPackagesInput = packages is not null ? string.Join(" ", packages) : string.Empty;
            }
            catch
            {
                _containerPackagesInput = string.Empty;
            }
        }

        try
        {
            var dict = JsonSerializer.Deserialize<Dictionary<string, string>>(Server.Headers);
            if (dict is not null)
            {
                _headers = dict.Select(kv => new HeaderEntry { Key = kv.Key, Value = kv.Value }).ToList();
            }
        }
        catch
        {
            _headers = [];
        }
    }

    private void OnNameChanged(ChangeEventArgs e)
    {
        _name = e.Value?.ToString() ?? string.Empty;
        if (!_slugManuallyEdited)
        {
            _slug = Slugify(_name);
        }
    }

    private void OnSlugManuallyEdited(ChangeEventArgs e)
    {
        _slug = e.Value?.ToString() ?? string.Empty;
        _slugManuallyEdited = true;
        _slugError = null;
    }

    private void OnTransportChanged(ChangeEventArgs e)
    {
        _transport = e.Value?.ToString() ?? "remote_http";
        _testMessage = null;
    }

    private void OnContainerModeChanged(ChangeEventArgs e)
    {
        _containerMode = e.Value?.ToString() ?? "image";
        if (_containerMode == "image")
        {
            _containerRuntime = string.Empty;
            _containerPackagesInput = string.Empty;
        }
        else
        {
            _containerImage = string.Empty;
        }
        _testMessage = null;
    }

    private void UpdateHeaderKey(int index, string value)
    {
        if (index >= 0 && index < _headers.Count)
        {
            _headers[index].Key = value;
        }
    }

    private void UpdateHeaderValue(int index, string value)
    {
        if (index >= 0 && index < _headers.Count)
        {
            _headers[index].Value = value;
        }
    }

    private void AddHeader() => _headers.Add(new HeaderEntry());

    private void RemoveHeader(int index)
    {
        if (index >= 0 && index < _headers.Count)
        {
            _headers.RemoveAt(index);
        }
    }

    private async Task TestConnection()
    {
        _testMessage = null;
        _testSuccess = false;

        if (!TryBuildDraftServer(out var draftServer, out var errorMessage))
        {
            _testMessage = errorMessage;
            return;
        }

        try
        {
            var result = await UpstreamManager.TestConnectionAsync(draftServer);
            _testMessage = $"Connected to {result.ServerName} v{result.ServerVersion}. Found {result.ToolCount} tool(s): {(result.ToolNames.Count == 0 ? "(none)" : string.Join(", ", result.ToolNames))}";
            _testSuccess = true;
        }
        catch (Exception ex)
        {
            _testMessage = $"Connection failed: {ex.Message}";
            _testSuccess = false;
        }
    }

    private async Task HandleSubmit()
    {
        _formError = null;
        _slugError = null;

        if (string.IsNullOrWhiteSpace(_name))
        {
            _formError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_slug))
        {
            _slugError = "Slug is required.";
            return;
        }

        if (!Regex.IsMatch(_slug, @"^[a-z0-9][a-z0-9\-_]*$"))
        {
            _slugError = "Slug must start with a letter or number and contain only lowercase letters, numbers, hyphens, and underscores.";
            return;
        }

        var excludeId = Server?.Id;
        if (await ServerService.SlugExistsAsync(_slug, excludeId))
        {
            _slugError = "This slug is already in use.";
            return;
        }

        if (!TryBuildDraftServer(out var draftServer, out var errorMessage))
        {
            _formError = errorMessage;
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            if (IsEditMode)
            {
                await ServerService.UpdateServerAsync(
                    Server!.Id,
                    _slug,
                    _name.Trim(),
                    draftServer.Transport,
                    draftServer.Url,
                    draftServer.Headers,
                    draftServer.Command,
                    draftServer.Args,
                    draftServer.Env,
                    draftServer.ContainerImage,
                    draftServer.ContainerRuntime,
                    draftServer.ContainerPackages,
                    draftServer.ContainerMounts);
            }
            else
            {
                await ServerService.CreateServerAsync(
                    _slug,
                    _name.Trim(),
                    draftServer.Transport,
                    draftServer.Url,
                    draftServer.Headers,
                    draftServer.Command,
                    draftServer.Args,
                    draftServer.Env,
                    draftServer.ContainerImage,
                    draftServer.ContainerRuntime,
                    draftServer.ContainerPackages,
                    draftServer.ContainerMounts);
            }

            await OnSaved.InvokeAsync();
            _ = Task.Run(() => UpstreamManager.SyncAsync());
        }
        catch (Exception ex)
        {
            _formError = $"Failed to save: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private bool TryBuildDraftServer(out McpServer draftServer, out string errorMessage)
    {
        draftServer = new McpServer
        {
            Slug = _slug.Trim(),
            Name = _name.Trim(),
            Transport = _transport.Trim(),
            Headers = "{}",
            ContainerPackages = "[]",
            ContainerMounts = "[]"
        };

        if (draftServer.Transport == "remote_http")
        {
            if (string.IsNullOrWhiteSpace(_url))
            {
                errorMessage = "URL is required for Remote HTTP transport.";
                return false;
            }

            var headersDict = _headers
                .Where(h => !string.IsNullOrWhiteSpace(h.Key))
                .ToDictionary(h => h.Key.Trim(), h => h.Value.Trim());

            draftServer.Url = _url.Trim();
            draftServer.Headers = JsonSerializer.Serialize(headersDict);
            errorMessage = string.Empty;
            return true;
        }

        if (draftServer.Transport == "stdio_container")
        {
            if (_containerMode == "image" && string.IsNullOrWhiteSpace(_containerImage))
            {
                errorMessage = "Container image is required for pre-built image mode.";
                return false;
            }

            if (_containerMode == "autobuild" && string.IsNullOrWhiteSpace(_containerRuntime))
            {
                errorMessage = "Runtime is required for auto-build mode.";
                return false;
            }

            if (!TryNormalizeJsonObject(_envJson, out var normalizedEnvJson, out errorMessage))
            {
                return false;
            }

            if (!TryNormalizeJsonArray(_argsJson, out var normalizedArgsJson, out errorMessage))
            {
                return false;
            }

            if (!TryNormalizeJsonArray(_mountsJson, out var normalizedMountsJson, out errorMessage))
            {
                return false;
            }

            // Build packages JSON array from space-separated input
            var packagesJson = "[]";
            if (_containerMode == "autobuild" && !string.IsNullOrWhiteSpace(_containerPackagesInput))
            {
                var packages = _containerPackagesInput.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                packagesJson = JsonSerializer.Serialize(packages);
            }

            draftServer.Url = null;
            draftServer.Headers = "{}";
            draftServer.ContainerImage = _containerMode == "image" ? _containerImage.Trim() : null;
            draftServer.ContainerRuntime = _containerMode == "autobuild" ? _containerRuntime.Trim() : null;
            draftServer.ContainerPackages = packagesJson;
            draftServer.Command = string.IsNullOrWhiteSpace(_command) ? null : _command.Trim();
            draftServer.Args = normalizedArgsJson;
            draftServer.Env = normalizedEnvJson;
            draftServer.ContainerMounts = normalizedMountsJson;

            return true;
        }

        errorMessage = $"Unsupported transport '{draftServer.Transport}'.";
        return false;
    }

    private static bool TryNormalizeJsonObject(string json, out string normalized, out string errorMessage)
    {
        try
        {
            using var doc = JsonDocument.Parse(string.IsNullOrWhiteSpace(json) ? "{}" : json);
            if (doc.RootElement.ValueKind != JsonValueKind.Object)
            {
                normalized = string.Empty;
                errorMessage = "Env must be a JSON object.";
                return false;
            }

            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                if (prop.Value.ValueKind != JsonValueKind.String)
                {
                    normalized = string.Empty;
                    errorMessage = $"Env value for '{prop.Name}' must be a string.";
                    return false;
                }
            }

            normalized = doc.RootElement.GetRawText();
            errorMessage = string.Empty;
            return true;
        }
        catch (JsonException ex)
        {
            normalized = string.Empty;
            errorMessage = $"Invalid Env JSON: {ex.Message}";
            return false;
        }
    }

    private static bool TryNormalizeJsonArray(string json, out string normalized, out string errorMessage)
    {
        try
        {
            using var doc = JsonDocument.Parse(string.IsNullOrWhiteSpace(json) ? "[]" : json);
            if (doc.RootElement.ValueKind != JsonValueKind.Array)
            {
                normalized = string.Empty;
                errorMessage = "Args/Mounts must be JSON arrays.";
                return false;
            }

            normalized = doc.RootElement.GetRawText();
            errorMessage = string.Empty;
            return true;
        }
        catch (JsonException ex)
        {
            normalized = string.Empty;
            errorMessage = $"Invalid JSON array: {ex.Message}";
            return false;
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private static string Slugify(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
        {
            return string.Empty;
        }

        var slug = input.ToLowerInvariant();
        slug = Regex.Replace(slug, @"[^a-z0-9]+", "-");
        return slug.Trim('-');
    }
}
