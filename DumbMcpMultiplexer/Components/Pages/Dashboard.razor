@page "/"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@inject ServerService ServerService
@inject UpstreamManager UpstreamManager
@inject StdioLifecycleService StdioLifecycleService

<PageTitle>Dashboard — dumb-mcp-multiplexer</PageTitle>

<div>
    @* Header *@
    <div class="flex items-start justify-between mb-10">
        <div>
            <h1 class="font-serif italic text-5xl text-black leading-tight">Dashboard</h1>
            <p class="text-sm text-gray-500 mt-2">Manage your MCP server connections</p>
        </div>
        <button @onclick="OpenAddModal"
                class="flex items-center gap-2 bg-black text-white text-sm font-semibold px-5 py-2.5 border-2 border-black transition-all hover:bg-gray-800 mt-2 shrink-0">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Add Server
        </button>
    </div>

    @* Server grid or empty state *@
    @if (_servers is null)
    {
        <div class="flex items-center justify-center py-20">
            <p class="font-serif italic text-2xl text-gray-400">Loading...</p>
        </div>
    }
    else if (_servers.Count == 0)
    {
        <div class="flex flex-col items-center justify-center border-2 border-dashed border-black py-20 bg-white">
            <svg class="h-12 w-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M12 5v14"/>
            </svg>
            <p class="font-serif italic text-2xl text-black mb-2">No servers configured</p>
            <p class="text-gray-500 text-sm mb-6">Add your first MCP server to get started.</p>
            <button @onclick="OpenAddModal"
                    class="bg-black text-white text-sm font-semibold px-5 py-2.5 border-2 border-black transition-all hover:bg-gray-800">
                Add Server
            </button>
        </div>
    }
    else
    {
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var server in _servers)
            {
                <a href="/servers/@server.Slug"
                   class="group block bg-white border-2 border-black shadow-[5px_5px_0_0_#000] p-5 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_#000] transition-all">
                    <div class="flex items-start justify-between mb-3">
                        <h2 class="font-serif italic text-xl text-black group-hover:underline leading-snug truncate">
                            @server.Name
                        </h2>
                        @{
                            var status = GetStatus(server);
                        }
                        <span class="ml-2 mt-1 shrink-0 inline-flex items-center gap-1 text-xs font-mono font-semibold px-2 py-0.5 @status.BadgeClass">
                            @if (status.ShowSpinner)
                            {
                                <svg class="h-3 w-3 animate-spin" viewBox="0 0 24 24" fill="none">
                                    <circle class="opacity-20" cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
                                    <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                                </svg>
                            }
                            @status.Label
                        </span>
                    </div>
                    <p class="text-xs font-mono text-gray-500 mb-1 truncate">@server.Slug</p>
                    @if (!string.IsNullOrEmpty(server.Url))
                    {
                        <p class="text-xs text-gray-400 truncate" title="@server.Url">@server.Url</p>
                    }
                </a>
            }
        </div>
    }
</div>

@* Add Server Modal *@
@if (_showAddModal)
{
    <ServerForm Server="null"
                OnSaved="HandleServerSaved"
                OnCancel="CloseAddModal" />
}

@code {
    private List<McpServer>? _servers;
    private bool _showAddModal;

    protected override async Task OnInitializedAsync()
    {
        await LoadServers();
    }

    private async Task LoadServers()
    {
        _servers = await ServerService.GetAllServersAsync();
    }

    private void OpenAddModal()
    {
        _showAddModal = true;
    }

    private void CloseAddModal()
    {
        _showAddModal = false;
    }

    private async Task HandleServerSaved()
    {
        _showAddModal = false;
        await LoadServers();
    }

    private ServerStatusBadge GetStatus(McpServer server)
    {
        if (!server.Enabled)
        {
            return new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400");
        }

        if (server.Transport == "stdio_package_runner" || server.Transport == "stdio_container")
        {
            if (!StdioLifecycleService.States.TryGetValue(server.Slug, out var lifecycle))
            {
                return new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400");
            }

            return lifecycle.State switch
            {
                LifecycleState.Running => new ServerStatusBadge("Running", "bg-emerald-500 text-white"),
                LifecycleState.Crashed => new ServerStatusBadge("Crashed", "bg-red-500 text-white"),
                LifecycleState.Restarting => new ServerStatusBadge("Restarting", "bg-amber-400 text-black", true),
                _ => new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400"),
            };
        }

        if (!UpstreamManager.Connections.ContainsKey(server.Slug))
        {
            return new ServerStatusBadge("Stopped", "bg-gray-100 text-gray-600 border border-gray-400");
        }

        var health = GetHealthStatus(server.Slug);
        return health == UpstreamHealthStatus.Degraded
            ? new ServerStatusBadge("Degraded", "bg-amber-400 text-black")
            : new ServerStatusBadge("Running", "bg-emerald-500 text-white");
    }

    private UpstreamHealthStatus GetHealthStatus(string slug)
    {
        if (!UpstreamManager.Connections.ContainsKey(slug))
            return UpstreamHealthStatus.Degraded;
        return UpstreamManager.HealthStatuses.TryGetValue(slug, out var status)
            ? status
            : UpstreamHealthStatus.Healthy;
    }

    private sealed record ServerStatusBadge(string Label, string BadgeClass, bool ShowSpinner = false);
}
