@page "/profiles"
@rendermode InteractiveServer
@using DumbMcpMultiplexer.Models
@using DumbMcpMultiplexer.Services
@inject ProfileService ProfileService

<PageTitle>Profiles - Dumb MCP Multiplexer</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-100">Profiles</h2>
            <p class="text-gray-400 mt-1">Choose which servers and tools are available for each profile endpoint</p>
        </div>
        <button @onclick="CreateProfile"
                class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg font-medium transition-colors">
            New profile
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_status))
    {
        <div class="text-sm text-emerald-300">@_status</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="p-3 rounded-lg border border-red-500/30 bg-red-500/10 text-red-300 text-sm">@_error</div>
    }

    <div class="grid gap-4">
        @foreach (var profile in _profiles)
        {
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <div class="flex items-center gap-2">
                            <h3 class="text-lg font-semibold text-gray-100">@profile.Name</h3>
                            @if (profile.IsDefault)
                            {
                                <span class="px-2 py-0.5 text-xs rounded-md bg-indigo-500/20 text-indigo-300 border border-indigo-500/30">Default</span>
                            }
                        </div>
                        <p class="text-sm text-gray-400 mt-1">@profile.IncludedServerCount server(s) included</p>
                        <p class="text-xs text-gray-500 mt-1">Endpoint: <code class="text-gray-300">/mcp/@Uri.EscapeDataString(profile.Name)</code></p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button @onclick="() => EditProfileAsync(profile.Id)"
                                class="px-3 py-1.5 text-sm rounded-lg border border-gray-700 text-gray-200 hover:bg-gray-800 transition-colors">
                            Edit
                        </button>
                        <button @onclick="() => DeleteProfileAsync(profile.Id)"
                                class="px-3 py-1.5 text-sm rounded-lg border border-red-500/40 text-red-300 hover:bg-red-500/10 transition-colors">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (_editor is not null)
{
    <div class="fixed inset-0 z-50 bg-black/60 p-4 overflow-auto">
        <div class="max-w-4xl mx-auto bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-5">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-semibold text-gray-100">@(_editing ? "Edit profile" : "Create profile")</h3>
                <button @onclick="CancelEdit" class="text-gray-400 hover:text-gray-200">✕</button>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
                <label class="space-y-2">
                    <span class="text-sm text-gray-300">Name</span>
                    <input @bind="_editor.Name"
                           class="w-full px-3 py-2 bg-gray-950 border border-gray-700 rounded-lg text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </label>
                <label class="inline-flex items-center gap-2 mt-7">
                    <input type="checkbox" @bind="_editor.IsDefault" />
                    <span class="text-sm text-gray-300">Mark as default</span>
                </label>
            </div>

            <div class="rounded-lg border border-gray-800 bg-gray-950 p-4">
                <label class="inline-flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" @bind="_editor.CodeModeEnabled" />
                    <span class="text-sm text-gray-100 font-medium">Enable Code Mode</span>
                </label>
                <p class="mt-2 text-xs text-gray-400">
                    When enabled, downstream clients see only <code class="text-gray-300">search</code>,
                    <code class="text-gray-300">get_schema</code>, and <code class="text-gray-300">execute</code> meta-tools
                    instead of the full tool list. Clients discover tools on demand and invoke them by writing Lua code
                    in a sandboxed environment.
                </p>
            </div>

            <div class="space-y-4 max-h-[55vh] overflow-auto pr-2">
                @foreach (var server in _editor.Servers.OrderBy(s => s.ServerName))
                {
                    <div class="rounded-lg border border-gray-800 bg-gray-950 p-4 space-y-3">
                        <div class="flex items-center justify-between">
                            <label class="inline-flex items-center gap-2">
                                <input type="checkbox" @bind="server.Included" />
                                <span class="text-sm text-gray-100 font-medium">@server.ServerName</span>
                                <span class="text-xs text-gray-500">@server.ServerSlug</span>
                            </label>

                            @if (server.Included)
                            {
                                <label class="inline-flex items-center gap-2 text-sm text-gray-300">
                                    <input type="checkbox" @bind="server.Enabled" />
                                    Enabled in profile
                                </label>
                            }
                        </div>

                        @if (server.Included && server.ToolCapabilities.Count > 0)
                        {
                            <div class="pl-5 space-y-2">
                                <p class="text-xs uppercase tracking-wide text-gray-500">Tools</p>
                                @foreach (var tool in server.ToolCapabilities.OrderBy(t => t.Name))
                                {
                                    <label class="inline-flex items-center gap-2 mr-4 text-sm text-gray-300">
                                        <input type="checkbox" @bind="tool.Enabled" />
                                        <span class="font-mono">@tool.Name</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="flex justify-end gap-2">
                <button @onclick="CancelEdit"
                        class="px-3 py-2 text-sm rounded-lg border border-gray-700 text-gray-200 hover:bg-gray-800 transition-colors">
                    Cancel
                </button>
                <button @onclick="SaveProfileAsync"
                        class="px-3 py-2 text-sm rounded-lg bg-indigo-600 text-white hover:bg-indigo-500 transition-colors">
                    Save profile
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProfileService.ProfileSummary> _profiles = [];
    private ProfileService.ProfileEditModel? _editor;
    private bool _editing;
    private string? _status;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfilesAsync();
    }

    private async Task LoadProfilesAsync()
    {
        _profiles = await ProfileService.GetSummariesAsync();
    }

    private async Task CreateProfile()
    {
        _error = null;
        _status = null;
        _editing = false;
        _editor = await ProfileService.CreateDraftAsync();
    }

    private async Task EditProfileAsync(string profileId)
    {
        _error = null;
        _status = null;
        _editing = true;
        _editor = await ProfileService.GetForEditAsync(profileId);
    }

    private async Task SaveProfileAsync()
    {
        if (_editor is null)
        {
            return;
        }

        _error = null;
        _status = null;

        try
        {
            await ProfileService.SaveAsync(_editor);
            _editor = null;
            await LoadProfilesAsync();
            _status = "Profile saved.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task DeleteProfileAsync(string profileId)
    {
        _error = null;
        _status = null;

        await ProfileService.DeleteAsync(profileId);
        await LoadProfilesAsync();
        _status = "Profile deleted.";
    }

    private void CancelEdit()
    {
        _editor = null;
    }
}
